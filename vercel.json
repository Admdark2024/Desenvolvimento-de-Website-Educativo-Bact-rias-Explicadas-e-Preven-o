{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/outputs/index.html" },
    { "source": "/styles.css", "destination": "/outputs/styles.css" },
    { "source": "/script.js", "destination": "/outputs/script.js" }
  ]
}
